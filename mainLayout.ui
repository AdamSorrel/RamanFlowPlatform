QTabBar {
	background-color: #1E2529;
	width: 100%; 
}

QTabBar::tab {
        /*background: #1E2529;*/
		background: #171D20;
        padding: 10px;
        /*border-top-radius: 10px;*/
		border-top-left-radius: 10px;
		border-top-right-radius: 10px;
		/*border: 5px #1E2529;*/
    }

QTabBar::tab:selected {
        /*background: #2F3133;*/
		background: #1E2529;
       	/*border-top-radius: 10px;*/
		border-top-left-radius: 10px;
		border-top-right-radius: 10px;
		border-bottom-left-radius: 0px;
		border-bottom-right-radius: 0px;
    }

QTableWidget{
	border: 0px solid;
	background-color: #2F3133;
	/*padding: 10px;*/
	/*background-color: #040f13;*/
	border-radius: 5px;
	color: #2F3133;				/* Text color */
}

/* Horizontal header in QTableWidget */
QHeaderView::section:horizontal {
	background-color: #2F3133;	/* Background color */
	color: white;               				/* Text color */
}
/* Vertical header in QTableWidget*/
QHeaderView::section:vertical {
	background-color: #2F3133;	/* Background color */
	color: white;               				/* Text color */
}

/* Corner button in QTableWidget */
QTableCornerButton::section {
    background-color: #2F3133;  /* Background color */
