QTabWidget {
	/* This determines the color behind the QWidget in the MDA tab. Mostly visible through rounded corners.*/
	background-color: #1E2529;
	background: #1E2529;
	/*border: 5px #FF0000;
	margin: 5px #FF0000;*/
}

QTabWidget::pane {
	/*background-color: #1E2529;
	background: #1E2529;
	border: 5px #1E2529;
